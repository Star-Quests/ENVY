{
  "name": "envy",
  "version": "1.0.0",
  "description": "ENVY - Professional Crypto Trading Journal",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "frontend": "cd frontend && npx http-server --port=3000 --cors --silent",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend\"",
    "build": "echo 'No build step required'",
    "production": "concurrently \"npm start\" \"npm run frontend\"",
    "migrate": "node backend/migrate.js",
    "fix": "node fix-system.js",
    "postinstall": "node backend/migrate.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bignumber.js": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "node-cron": "^3.0.3",
    "simple-git": "^3.27.0",
    "sql.js": "^1.8.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "nodemon": "^3.0.2"
  }
}